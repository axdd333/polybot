# Polymarket Arb Bot Configuration
# Copy this file to .env and fill in your credentials

# Option 1: Private key authentication (for self-custody wallets)
# POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Option 2: Builder API key authentication (for programmatic trading)
# Get these from Polymarket Settings > Relayer API Keys
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_secret_here
POLY_API_PASSPHRASE=your_passphrase_here

# Log level (debug, info, warn, error)
RUST_LOG=info

# Paper trading mode (set to 1 to enable, 0 or unset for live trading)
PAPER_TRADING=1
